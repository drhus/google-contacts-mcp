{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/.well-known/oauth-authorization-server", "destination": "/api/well-known/oauth-authorization-server" },
    { "source": "/.well-known/oauth-protected-resource", "destination": "/api/well-known/oauth-protected-resource" },
    { "source": "/.well-known/oauth-protected-resource/mcp", "destination": "/api/well-known/oauth-protected-resource" },
    { "source": "/register", "destination": "/api/register" },
    { "source": "/authorize", "destination": "/api/authorize" },
    { "source": "/callback", "destination": "/api/callback" },
    { "source": "/token", "destination": "/api/token" },
    { "source": "/mcp", "destination": "/api/mcp" },
    { "source": "/", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.ts": { "maxDuration": 10 },
    "api/mcp.ts": { "maxDuration": 60 },
    "api/authorize.ts": { "maxDuration": 10 },
    "api/callback.ts": { "maxDuration": 10 },
    "api/token.ts": { "maxDuration": 10 },
    "api/register.ts": { "maxDuration": 10 },
    "api/well-known/oauth-authorization-server.ts": { "maxDuration": 10 },
    "api/well-known/oauth-protected-resource.ts": { "maxDuration": 10 }
  }
}
